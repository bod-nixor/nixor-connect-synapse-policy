# Production-shaped Synapse configuration. Replace every replace-with-* value
# and keep live secrets/configuration outside Git.
server_name: "replace-with-immutable-matrix-server-name"
public_baseurl: "https://matrix.nixorcorporate.com/"
pid_file: /var/lib/synapse/homeserver.pid

listeners:
  - port: 8008
    type: http
    tls: false
    bind_addresses:
      - "127.0.0.1"
      - "::1"
    x_forwarded: true
    resources:
      - names:
          - client
          - federation
        compress: false

# SQLite is for isolated tests only. Production must use PostgreSQL.
database:
  name: psycopg2
  txn_limit: 10000
  args:
    user: synapse
    password: "replace-with-postgresql-password"
    database: synapse
    host: "replace-with-postgresql-host"
    port: 5432
    cp_min: 5
    cp_max: 10

log_config: "/etc/synapse/log.config"
media_store_path: /var/lib/synapse/media_store
registration_shared_secret: "replace-with-random-registration-secret"
macaroon_secret_key: "replace-with-random-macaroon-secret"
form_secret: "replace-with-random-form-secret"
signing_key_path: "/var/lib/synapse/server.signing.key"
report_stats: false

enable_registration: false
password_config:
  enabled: false

trusted_key_servers:
  - server_name: "matrix.org"

modules:
  - module: nixor_policy_checker.NixorPolicyChecker
    config:
      governance_api_url: "https://panapticon.internal/internal/policy/check"
      policy_shared_secret_file: "/run/secrets/nixor-policy-shared-secret"
      fail_closed: true
